# Next.js storefront
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Strapi (server-side; use http://strapi:1337 in Docker Compose)
STRAPI_API_URL=http://localhost:1337
STRAPI_API_TOKEN=
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Shared secret for create-order / verify-payment commerce routes (must match Strapi COMMERCE_INTERNAL_SECRET)
COMMERCE_INTERNAL_SECRET=generate-a-long-random-string

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="The Blissful Soul <noreply@example.com>"
ADMIN_EMAIL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google-calendar/callback

NEXT_PUBLIC_FB_PIXEL_ID=

# Instagram — live grid on homepage (optional). Profile: https://www.instagram.com/pragya.vijh_astrotalks/
# Option A: Meta Instagram Graph API (Business/Creator account linked to a Facebook Page).
#   INSTAGRAM_USER_ID = Instagram Business Account ID (numeric), from Graph API / Meta dashboard.
#   INSTAGRAM_ACCESS_TOKEN = long-lived Page or User token with permissions to read that IG account's media.
# Option B: Third-party widget iframe src (e.g. SnapWidget / Elfsight) — paste the iframe URL only:
#   NEXT_PUBLIC_INSTAGRAM_WIDGET_SRC=https://...
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
NEXT_PUBLIC_INSTAGRAM_WIDGET_SRC=

CRON_SECRET=

# Legacy Prisma DB — Strapi imports catalog on boot when IMPORT_LEGACY_CATALOG=true (Docker: host `db`)
LEGACY_DATABASE_URL=postgresql://blissful:blissful_dev@localhost:5432/blissful_soul
IMPORT_LEGACY_CATALOG=false
IMPORT_LEGACY_FORCE=false

# Strapi Docker (see docker-compose.yml)
STRAPI_DB_PASSWORD=strapi_dev
STRAPI_JWT_SECRET=
STRAPI_ADMIN_JWT_SECRET=
STRAPI_APP_KEYS=key1,key2,key3,key4
